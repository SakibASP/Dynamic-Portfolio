@using Portfolio.Domain

@{
    ViewData["Title"] = "Home";
    var Cover = (PROFILE_COVER?)ViewBag.Cover;
    var rootpath = (string)ViewBag.rootPath;

    string coverName = Cover?.COVER_NAME ?? ViewBag.Name as string ?? "Md. Sakibur Rahman";
    string coverDesc = Cover?.COVER_DESC ?? ViewBag.Bio as string ?? "Software Developer · Clean Architecture enthusiast";
    string avatar = Cover?.COVER_IMAGE != null
        ? Url.Content(Cover.COVER_IMAGE.Replace(rootpath, ""))
        : Url.Content("~/assets/img/about.jpg");

    var firstName = coverName.Split(' ').FirstOrDefault() ?? coverName;
    var restName  = coverName.Length > firstName.Length ? coverName.Substring(firstName.Length) : "";
}

<input type="hidden" id="coverName" value="@coverName" />
<input type="hidden" id="coverDesc" value="@coverDesc" />

<section id="hero">
    <div class="hero-grid">
        <div class="hero-avatar-wrap" data-aos="zoom-in" data-aos-duration="800">
            <img src="@avatar" alt="@coverName" />
        </div>

        <div data-aos="fade-up" data-aos-delay="150">
            <span class="hero-eyebrow">
                <span class="dot"></span>
                Available for new projects
            </span>

            <h1 class="hero-title">
                Hi, I'm <span class="accent">@firstName</span>@restName
            </h1>

            <p class="hero-typed" id="heroTyped">
                <span class="typed-text"></span><span class="typed-cursor">|</span>
            </p>

            <p class="hero-bio">@coverDesc</p>

            <div class="hero-actions">
                <a asp-action="About" asp-controller="MY_PROFILE" class="btn-primary-grad">
                    <i class="bi bi-person-circle"></i> About Me
                </a>
                <a asp-action="DownloadCV" asp-controller="CV" asp-route-filePath="@ViewBag.FilePath" class="btn-ghost">
                    <i class="bi bi-download"></i> Download CV
                </a>
                <a asp-action="Contact" asp-controller="MY_PROFILE" class="btn-ghost">
                    <i class="bi bi-chat-square-text"></i> Get in Touch
                </a>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        (function () {
            const phrases = [
                "Software Developer",
                ".NET & Clean Architecture",
                "Full-Stack Engineer",
                "Problem solver"
            ];
            const el = document.querySelector("#heroTyped .typed-text");
            if (!el) return;
            let i = 0, j = 0, del = false;
            (function loop() {
                const p = phrases[i];
                el.textContent = p.substring(0, j);
                if (!del && j < p.length) { j++; setTimeout(loop, 65); }
                else if (del && j > 0)    { j--; setTimeout(loop, 35); }
                else { del = !del; if (!del) i = (i + 1) % phrases.length; setTimeout(loop, del ? 1400 : 400); }
            })();
        })();
    </script>
}
