@model Portfolio.Domain.CONTACTS

@{ ViewData["Title"] = "New Message"; }

<section>
    <div class="admin-page narrow">
        <div class="admin-head">
            <div>
                <span class="eyebrow">Admin · Messages</span>
                <h2>New contact</h2>
            </div>
        </div>

        <form asp-action="Create" class="admin-form">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="field"><label asp-for="NAME"></label><input asp-for="NAME" /><span asp-validation-for="NAME" class="err"></span></div>
            <div class="field"><label asp-for="SUBJECT"></label><input asp-for="SUBJECT" /><span asp-validation-for="SUBJECT" class="err"></span></div>
            <div class="field"><label asp-for="EMAIL"></label><input asp-for="EMAIL" /><span asp-validation-for="EMAIL" class="err"></span></div>
            <div class="field"><label asp-for="PHONE"></label><input asp-for="PHONE" /><span asp-validation-for="PHONE" class="err"></span></div>
            <div class="field"><label asp-for="MESSAGE"></label><textarea asp-for="MESSAGE" rows="5"></textarea><span asp-validation-for="MESSAGE" class="err"></span></div>

            <div class="form-actions">
                <a asp-action="Index" class="btn-ghost">Cancel</a>
                <button type="submit" class="btn-primary-grad"><i class="bi bi-check2"></i> Create</button>
            </div>
        </form>
    </div>
</section>

@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }
