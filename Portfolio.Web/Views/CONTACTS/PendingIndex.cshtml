@model IEnumerable<Portfolio.Domain.CONTACTS>

@{ ViewData["Title"] = "Pending Messages"; }

<section>
    <div class="admin-page">
        <div class="admin-head">
            <div>
                <span class="eyebrow">Admin · Messages · Pending</span>
                <h2>@Model.Count() unread</h2>
            </div>
        </div>

        @if (Model.Any())
        {
            <div class="admin-table-wrap">
                <table class="admin-table">
                    <thead>
                        <tr><th>Name</th><th>Subject</th><th>Email</th><th>Phone</th><th style="width:120px;"></th></tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.NAME</td>
                            <td>@item.SUBJECT</td>
                            <td>@item.EMAIL</td>
                            <td>@item.PHONE</td>
                            <td>
                                <div class="actions">
                                    <a class="action-btn" asp-action="Details" asp-route-id="@item.AUTO_ID" title="Open"><i class="bi bi-eye"></i></a>
                                    <a class="action-btn danger" asp-action="Delete" asp-route-id="@item.AUTO_ID" title="Delete"><i class="bi bi-trash"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
        else { <div class="empty-state">All caught up — no pending messages.</div> }
    </div>
</section>
