@model Portfolio.Domain.CONTACTS

@{ ViewData["Title"] = "Message"; }

<section>
    <div class="admin-page narrow">
        <div class="admin-head">
            <div>
                <span class="eyebrow">Admin · Messages</span>
                <h2>@Model.SUBJECT</h2>
                <span class="sub">from @Model.NAME</span>
            </div>
        </div>

        <div class="admin-details">
            <div class="row"><div class="k">Status</div><div class="v">@(Model.IsConfirmed == 1 ? "Read" : "Unread")</div></div>
            <div class="row"><div class="k">Name</div><div class="v">@Model.NAME</div></div>
            <div class="row"><div class="k">Subject</div><div class="v">@Model.SUBJECT</div></div>
            <div class="row"><div class="k">Message</div><div class="v" style="white-space:pre-wrap;">@Model.MESSAGE</div></div>
            <div class="row"><div class="k">Email</div><div class="v">@Model.EMAIL</div></div>
            <div class="row"><div class="k">Phone</div><div class="v">@Model.PHONE</div></div>
        </div>

        <div class="form-actions">
            <a asp-action="Index" class="btn-ghost"><i class="bi bi-arrow-left"></i> Back</a>
        </div>
    </div>
</section>
