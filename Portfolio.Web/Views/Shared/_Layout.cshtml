<!DOCTYPE html>
<html lang="en" data-theme="dark">

<head>
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <meta name="color-scheme" content="dark light">

    <title>Md. Sakibur Rahman — @ViewData["Title"]</title>
    <meta content="" name="description">
    <meta content="" name="keywords">

    <link href="~/logo/SLogo.png" rel="icon">
    <link href="~/assets/img/apple-touch-icon.png" rel="apple-touch-icon">

    <!-- Fonts: Inter (body) + Space Grotesk (display) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700;800&display=swap" rel="stylesheet">

    <link href="~/css/home/layoutcontent.css" rel="stylesheet" />
    <!-- Vendor CSS Files -->
    <link href="~/assets/vendor/aos/aos.css" rel="stylesheet">
    <link href="~/assets/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/assets/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
    <link href="~/assets/vendor/glightbox/css/glightbox.min.css" rel="stylesheet">
    <link href="~/assets/vendor/swiper/swiper-bundle.min.css" rel="stylesheet">
    <link href="~/assets/vendor/boxicons/css/boxicons.min.css" rel="stylesheet" />
    <!-- Template Main CSS -->
    <link href="~/assets/css/style.css" rel="stylesheet" />
    <!-- DataTables -->
    <link href="https://cdn.datatables.net/1.11.5/css/jquery.dataTables.min.css" rel="stylesheet">
    <!-- Legacy site CSS -->
    <link href="~/css/site.css" rel="stylesheet" />
    <!-- New modern theme — MUST be last so it wins the cascade -->
    <link href="~/css/theme.css" rel="stylesheet" asp-append-version="true" />

    <!-- Load theme before paint to avoid flash -->
    <script>
        (function () {
            var t = localStorage.getItem("theme") || "dark";
            document.documentElement.setAttribute("data-theme", t);
        })();
    </script>

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-D8P8SMRTS1"></script>
    <script>
        window.dataLayer = window.dataLayer || [];
        function gtag() { dataLayer.push(arguments); }
        gtag('js', new Date());
        gtag('config', 'G-D8P8SMRTS1');
    </script>
</head>

<body>
    <!-- ======= Header ======= -->
    <header id="header" class="fixed-top">
        <div class="container-fluid d-flex justify-content-between align-items-center">

            <a asp-action="Index" asp-controller="Home" class="logo"><img src="~/logo/myLogo.png" class="img-fluid" /></a>

            <nav id="navbar" class="navbar order-last order-lg-0">
                <ul>
                    <li class="nav-item"><a asp-action="Index" asp-controller="Home">Home</a></li>
                    <li class="nav-item"><a asp-action="About" asp-controller="MY_PROFILE">About</a></li>
                    <li class="nav-item"><a asp-action="Resume" asp-controller="MY_PROFILE">Resume</a></li>
                    <li class="nav-item"><a asp-action="Projects" asp-controller="MY_PROFILE">Projects</a></li>
                    <li class="nav-item"><a asp-action="Contact" asp-controller="MY_PROFILE">Contact</a></li>
                    <li class="nav-item"><a asp-action="Visitors" asp-controller="MY_PROFILE">Visitors</a></li>
                    @if (User.Identity!.IsAuthenticated)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#">Admin</a>
                            <ul>
                                <li class="nav-item dropdown">
                                    <a class="nav-link" href="#">Edit About</a>
                                    <ul>
                                        <li class="nav-item"><a asp-action="Index" asp-controller="PROFILE_COVER">Edit Cover</a></li>
                                        <li class="nav-item"><a asp-action="Index" asp-controller="MY_PROFILE">Edit Profile</a></li>
                                        <li class="nav-item"><a asp-action="Index" asp-controller="MY_SKILL">Edit Skills</a></li>
                                    </ul>
                                </li>
                                <li class="nav-item dropdown">
                                    <a class="nav-link" href="#">Resume</a>
                                    <ul>
                                        <li class="nav-item"><a asp-action="Index" asp-controller="EDUCATION">Edit Education</a></li>
                                        <li class="nav-item"><a asp-action="Index" asp-controller="EXPERIENCE">Edit Experience</a></li>
                                    </ul>
                                </li>
                                <li class="nav-item"><a asp-action="Index" asp-controller="CV">Edit CV</a></li>
                                <li class="nav-item"><a asp-action="Index" asp-controller="PROJECTS">Edit Projects</a></li>
                                <li class="nav-item"><a asp-action="Index" asp-controller="DESCRIPTIONs">Edit Description</a></li>
                                <li class="nav-item"><a asp-action="Index" asp-controller="Logs">Logs</a></li>
                                <li class="nav-item">
                                    @if (ViewBag.Message != null && ViewBag.Message != "0")
                                    {
                                        <a style="color:#f87171;" asp-action="PendingIndex" asp-controller="CONTACTS">Messages <span>@ViewBag.Message</span></a>
                                    }
                                    else
                                    {
                                        <a asp-action="PendingIndex" asp-controller="CONTACTS">Messages</a>
                                    }
                                </li>
                            </ul>
                        </li>
                    }
                </ul>
                <i class="bi bi-list mobile-nav-toggle"></i>
            </nav>

            <div class="header-social-links d-flex align-items-center">
                @{
                    var githubLink    = @"https://github.com/SakibASP";
                    var linkedinLink  = @"https://www.linkedin.com/in/md-sakibur-rahman-070853196/";
                    var youtubeLink   = @"https://www.youtube.com/@SakibCoding";
                    var facebookLink  = @"https://www.facebook.com/sakibur.cse";
                    var instagramLink = @"https://www.instagram.com/sakibur_rocky/";
                    var tiktokLink    = @"https://www.tiktok.com/@sakibur_rocky";
                    var twitterLink   = @"https://twitter.com/Sakibur78738178";
                }
                <a href="@githubLink" target="_blank" aria-label="GitHub"><i class="bi bi-github"></i></a>
                <a href="@linkedinLink" target="_blank" aria-label="LinkedIn"><i class="bi bi-linkedin"></i></a>
                <a href="@youtubeLink" target="_blank" aria-label="YouTube"><i class="bi bi-youtube"></i></a>
                <a href="@facebookLink" target="_blank" aria-label="Facebook"><i class="bi bi-facebook"></i></a>
                <a href="@instagramLink" target="_blank" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
                <a href="@tiktokLink" target="_blank" aria-label="TikTok"><i class="bi bi-tiktok"></i></a>
                <a href="@twitterLink" target="_blank" aria-label="Twitter"><i class="bi bi-twitter"></i></a>

                <button type="button" class="theme-toggle" id="themeToggle" aria-label="Toggle theme" title="Toggle theme">
                    <i class="bi bi-moon-stars-fill" id="themeIcon"></i>
                </button>
            </div>
        </div>
    </header>

    <div>
        <div class="myContainer">
            @RenderBody()
        </div>
    </div>

    <footer id="footer">
        <div class="container">
            <div><small>&copy; @DateTime.Now.Year <strong>Md. Sakibur Rahman</strong></small></div>
            <div><small>Crafted with <span style="color: var(--brand-1);">.NET 10</span> + Clean Architecture</small></div>
            <div><small><a href="https://github.com/SakibASP/Dynamic-Portfolio" target="_blank">Source</a></small></div>
            <div>
                @if (User.Identity.IsAuthenticated)
                {
                    <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/", new { area = "" })" method="post">
                        <input type="submit" value="Logout" />
                    </form>
                }
                else
                {
                    <a asp-area="Identity" asp-page="/Account/Login">Login</a>
                }
            </div>
        </div>
    </footer>

    <div id="preloader"></div>
    <a href="#" class="back-to-top d-flex align-items-center justify-content-center"><i class="bi bi-arrow-up-short"></i></a>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/assets/vendor/purecounter/purecounter_vanilla.js"></script>
    <script src="~/assets/vendor/aos/aos.js"></script>
    <script src="~/assets/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/assets/vendor/glightbox/js/glightbox.min.js"></script>
    <script src="~/assets/vendor/isotope-layout/isotope.pkgd.min.js"></script>
    <script src="~/assets/vendor/swiper/swiper-bundle.min.js"></script>
    <script src="~/assets/vendor/waypoints/noframework.waypoints.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/assets/js/main.js"></script>
    <script src="~/assets/js/location-tracking.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.datatables.net/1.11.5/js/jquery.dataTables.min.js"></script>

    <!-- Theme toggle -->
    <script>
        (function () {
            var btn = document.getElementById("themeToggle");
            var icon = document.getElementById("themeIcon");
            function sync() {
                var t = document.documentElement.getAttribute("data-theme");
                icon.className = t === "light" ? "bi bi-sun-fill" : "bi bi-moon-stars-fill";
            }
            sync();
            btn && btn.addEventListener("click", function () {
                var t = document.documentElement.getAttribute("data-theme") === "light" ? "dark" : "light";
                document.documentElement.setAttribute("data-theme", t);
                localStorage.setItem("theme", t);
                sync();
            });
        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)

    <script>
        $(function () { $(".table").DataTable(); });
    </script>
</body>
</html>
