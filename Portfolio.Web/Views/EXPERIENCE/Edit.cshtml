@model Portfolio.Domain.EXPERIENCE
@using Portfolio.Web.Common

@{
    ViewData["Title"] = "Edit Experience";
    var rootpath = (string?)ViewData["rootPath"] ?? "";
    var logoUrl  = Utility.ToWebUrl(Model.LOGO, rootpath);
}

<section>
    <div class="admin-page narrow">
        <div class="admin-head">
            <div>
                <span class="eyebrow">Admin · Experience</span>
                <h2>Edit entry</h2>
            </div>
        </div>

        <form asp-action="Edit" enctype="multipart/form-data" class="admin-form">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="AUTO_ID" />

            <div class="field"><label asp-for="DESIGNATION"></label><input asp-for="DESIGNATION" /></div>
            <div class="field"><label asp-for="INSTITUTE">Company / Institute</label><input asp-for="INSTITUTE" /></div>
            <div class="field"><label asp-for="COMPANY_URL">Company URL</label><input asp-for="COMPANY_URL" /></div>
            <div class="field"><label asp-for="FROM_DATE"></label><input asp-for="FROM_DATE" /></div>
            <div class="field"><label asp-for="TO_DATE"></label><input asp-for="TO_DATE" /></div>
            <div class="field"><label asp-for="SORT_ORDER"></label><input asp-for="SORT_ORDER" /></div>

            <div class="field">
                <label asp-for="LOGO">Company logo (leave empty to keep)</label>
                <input type="file" id="fileInput" accept="image/*" name="LOGO_FILE" class="form-control-file" />
                @if (!string.IsNullOrEmpty(logoUrl))
                {
                    <img class="thumb" style="margin-top:.5rem;max-height:90px;background:#fff;padding:.3rem;border-radius:6px;" src="@logoUrl" />
                }
                <div id="file-preview"></div>
            </div>

            <div class="field inline">
                <label><input type="checkbox" asp-for="IS_CURRENT" /> This is my current role</label>
            </div>

            <div class="form-actions">
                <a asp-action="Index" class="btn-ghost">Cancel</a>
                <button type="submit" class="btn-primary-grad"><i class="bi bi-check2"></i> Save</button>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="~/js/file-preview.js"></script>
}
