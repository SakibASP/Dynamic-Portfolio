@model Portfolio.Domain.DESCRIPTION_TYPE

@{ ViewData["Title"] = "Edit Type"; }

<section>
    <div class="admin-page narrow">
        <div class="admin-head">
            <div>
                <span class="eyebrow">Admin · Description types</span>
                <h2>Edit type</h2>
            </div>
        </div>

        <form asp-action="Edit" class="admin-form">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="AUTO_ID" />
            <div class="field"><label asp-for="TYPE"></label><input asp-for="TYPE" /><span asp-validation-for="TYPE" class="err"></span></div>

            <div class="form-actions">
                <a asp-action="Index" class="btn-ghost">Cancel</a>
                <button type="submit" class="btn-primary-grad"><i class="bi bi-check2"></i> Save</button>
            </div>
        </form>
    </div>
</section>

@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }
