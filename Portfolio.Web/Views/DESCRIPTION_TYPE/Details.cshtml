@model Portfolio.Domain.DESCRIPTION_TYPE

@{ ViewData["Title"] = "Type Details"; }

<section>
    <div class="admin-page narrow">
        <div class="admin-head">
            <div>
                <span class="eyebrow">Admin · Description types</span>
                <h2>@Model.TYPE</h2>
            </div>
        </div>

        <div class="admin-details">
            <div class="row"><div class="k">Type</div><div class="v">@Model.TYPE</div></div>
        </div>

        <div class="form-actions">
            <a asp-action="Index" class="btn-ghost"><i class="bi bi-arrow-left"></i> Back</a>
            <a asp-action="Edit" asp-route-id="@Model?.AUTO_ID" class="btn-primary-grad"><i class="bi bi-pencil"></i> Edit</a>
        </div>
    </div>
</section>
