@model Portfolio.Domain.PROJECTS

@{ ViewData["Title"] = "Delete Project"; }

<section>
    <div class="admin-page narrow">
        <div class="admin-head center">
            <span class="eyebrow">Admin · Projects</span>
            <h2>Delete this project?</h2>
            <span class="sub">This action cannot be undone.</span>
        </div>

        <div class="admin-details">
            <div class="row"><div class="k">Name</div><div class="v">@Model.PROJECT_NAME</div></div>
            <div class="row">
                <div class="k">Logo</div>
                <div class="v">
                    @if (Model.LOGO != null && Model.LOGO.Length > 0)
                    {
                        <img class="preview" src="data:image/*;base64,@System.Convert.ToBase64String(Model.LOGO)" alt="@Model.PROJECT_NAME" />
                    }
                </div>
            </div>
        </div>

        <form asp-action="Delete" class="form-actions center">
            <input type="hidden" asp-for="AUTO_ID" />
            <a asp-action="Index" class="btn-ghost">Cancel</a>
            <button type="submit" class="btn-danger-solid"><i class="bi bi-trash"></i> Delete</button>
        </form>
    </div>
</section>
