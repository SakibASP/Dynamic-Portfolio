@model Portfolio.Domain.PROJECTS

@{
    ViewData["Title"] = "Project Details";
    var descriptions = ViewData["DESCRIPTIONs"] as List<Portfolio.Domain.DESCRIPTION>;
}

<section>
    <div class="admin-page">
        <div class="admin-head">
            <div>
                <span class="eyebrow">Project</span>
                <h2>@Model.PROJECT_NAME</h2>
            </div>
        </div>

        <div class="admin-details">
            <div class="row"><div class="k">Name</div><div class="v">@Model.PROJECT_NAME</div></div>
            <div class="row">
                <div class="k">Logo</div>
                <div class="v">
                    @if (Model.LOGO != null && Model.LOGO.Length > 0)
                    {
                        <img class="preview" src="data:image/*;base64,@System.Convert.ToBase64String(Model.LOGO)" alt="@Model.PROJECT_NAME" />
                    }
                    else { <span style="color:var(--dim);">—</span> }
                </div>
            </div>
        </div>

        @if (descriptions != null && descriptions.Any())
        {
            <h3 style="margin-top:2rem;font-size:0.75rem;font-family:var(--font-mono);text-transform:uppercase;letter-spacing:0.12em;color:var(--dim);font-weight:500;">Descriptions</h3>
            <div class="admin-details">
                @foreach (var d in descriptions)
                {
                    <div class="row"><div class="k">#@d.AUTO_ID</div><div class="v">@d.DESCRIPTION_TEXT</div></div>
                }
            </div>
        }

        <div class="form-actions">
            <a asp-action="Index" class="btn-ghost"><i class="bi bi-arrow-left"></i> Back</a>
            <a asp-action="Edit" asp-route-id="@Model.AUTO_ID" class="btn-primary-grad"><i class="bi bi-pencil"></i> Edit</a>
        </div>
    </div>
</section>
