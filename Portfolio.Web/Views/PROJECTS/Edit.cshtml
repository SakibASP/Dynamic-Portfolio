@model Portfolio.Domain.PROJECTS

@{ ViewData["Title"] = "Edit Project"; }

<section>
    <div class="admin-page narrow">
        <div class="admin-head">
            <div>
                <span class="eyebrow">Admin · Projects</span>
                <h2>Edit project</h2>
            </div>
        </div>

        <form asp-action="Edit" enctype="multipart/form-data" class="admin-form">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="AUTO_ID" />
            <input type="hidden" asp-for="LOGO" />

            <div class="field"><label asp-for="PROJECT_NAME"></label><input asp-for="PROJECT_NAME" /><span asp-validation-for="PROJECT_NAME" class="err"></span></div>

            @if (Model.LOGO != null && Model.LOGO.Length > 0)
            {
                <div class="field">
                    <label>Current logo</label>
                    <img class="preview" src="data:image/*;base64,@System.Convert.ToBase64String(Model.LOGO)" alt="current" />
                </div>
            }

            <div class="field">
                <label asp-for="LOGO">Replace logo</label>
                <input type="file" id="fileInput" accept="image/*" asp-for="LOGO" class="form-control-file" />
                <span asp-validation-for="LOGO" class="err"></span>
                <div id="file-preview"></div>
            </div>

            <div class="form-actions">
                <a asp-action="Index" class="btn-ghost">Cancel</a>
                <button type="submit" class="btn-primary-grad"><i class="bi bi-check2"></i> Save</button>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="~/js/file-preview.js"></script>
}
