@model Portfolio.Domain.PROJECTS

@{ ViewData["Title"] = "New Project"; }

<section>
    <div class="admin-page narrow">
        <div class="admin-head">
            <div>
                <span class="eyebrow">Admin · Projects</span>
                <h2>New project</h2>
            </div>
        </div>

        <form asp-action="Create" enctype="multipart/form-data" class="admin-form">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="field"><label asp-for="PROJECT_NAME"></label><input asp-for="PROJECT_NAME" /><span asp-validation-for="PROJECT_NAME" class="err"></span></div>
            <div class="field">
                <label asp-for="LOGO">Logo image</label>
                <input type="file" id="fileInput" accept="image/*" asp-for="LOGO" class="form-control-file" />
                <span asp-validation-for="LOGO" class="err"></span>
                <div id="file-preview"></div>
            </div>

            <div class="form-actions">
                <a asp-action="Index" class="btn-ghost">Cancel</a>
                <button type="submit" class="btn-primary-grad"><i class="bi bi-check2"></i> Create</button>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="~/js/file-preview.js"></script>
}
