@model IEnumerable<Portfolio.Domain.PROJECTS>

@{ ViewData["Title"] = "Projects"; }

<section>
    <div class="admin-page">
        <div class="admin-head">
            <div>
                <span class="eyebrow">Admin · Projects</span>
                <h2>All projects</h2>
            </div>
            <a asp-action="Create" class="btn-primary-grad"><i class="bi bi-plus-lg"></i> New project</a>
        </div>

        @if (Model.Any())
        {
            <div class="admin-table-wrap">
                <table class="admin-table">
                    <thead>
                        <tr><th style="width:96px;">Logo</th><th>Name</th><th style="width:160px;"></th></tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @if (item.LOGO != null && item.LOGO.Length > 0)
                                {
                                    <img class="thumb" src="data:image/*;base64,@System.Convert.ToBase64String(item.LOGO)" alt="@item.PROJECT_NAME" />
                                }
                            </td>
                            <td>@item.PROJECT_NAME</td>
                            <td>
                                <div class="actions">
                                    <a class="action-btn" asp-action="Edit"    asp-route-id="@item.AUTO_ID" title="Edit"><i class="bi bi-pencil"></i></a>
                                    <a class="action-btn" asp-action="Details" asp-route-id="@item.AUTO_ID" title="Details"><i class="bi bi-eye"></i></a>
                                    <a class="action-btn danger" asp-action="Delete" asp-route-id="@item.AUTO_ID" title="Delete"><i class="bi bi-trash"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
        else { <div class="empty-state">No projects yet.</div> }
    </div>
</section>
