@model Portfolio.Domain.DESCRIPTION

@{ ViewData["Title"] = "Description Details"; }

<section>
    <div class="admin-page narrow">
        <div class="admin-head">
            <div>
                <span class="eyebrow">Admin · Descriptions</span>
                <h2>Description #@Model.AUTO_ID</h2>
            </div>
        </div>

        <div class="admin-details">
            <div class="row"><div class="k">Text</div><div class="v">@Model.DESCRIPTION_TEXT</div></div>
            <div class="row"><div class="k">Type</div><div class="v">@Model.DESCRIPTION_TYPE_?.TYPE</div></div>
            <div class="row"><div class="k">Project</div><div class="v">@(Model.PROJECT_?.PROJECT_NAME ?? "—")</div></div>
            <div class="row"><div class="k">Experience</div><div class="v">@(Model.EXPERIENCE_?.INSTITUTE ?? "—")</div></div>
            <div class="row"><div class="k">Sort order</div><div class="v">@Model.SORT_ORDER</div></div>
        </div>

        <div class="form-actions">
            <a asp-action="Index" class="btn-ghost"><i class="bi bi-arrow-left"></i> Back</a>
            <a asp-action="Edit" asp-route-id="@Model?.AUTO_ID" class="btn-primary-grad"><i class="bi bi-pencil"></i> Edit</a>
        </div>
    </div>
</section>
