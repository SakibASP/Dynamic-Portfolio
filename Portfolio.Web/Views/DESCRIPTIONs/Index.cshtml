@model IEnumerable<Portfolio.Domain.DESCRIPTION>

@{ ViewData["Title"] = "Descriptions"; }

<section>
    <div class="admin-page">
        <div class="admin-head">
            <div>
                <span class="eyebrow">Admin · Descriptions</span>
                <h2>All descriptions</h2>
            </div>
            <a asp-action="Create" class="btn-primary-grad"><i class="bi bi-plus-lg"></i> New description</a>
        </div>

        @if (Model.Any())
        {
            <div class="admin-table-wrap">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>Text</th>
                            <th>Type</th>
                            <th>Project / Experience</th>
                            <th style="width:60px;">Order</th>
                            <th style="width:160px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td style="max-width:380px;">
                                <div style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@item.DESCRIPTION_TEXT</div>
                            </td>
                            <td><span class="country" style="background:rgba(190,242,100,0.08);border:1px solid rgba(190,242,100,0.25);color:var(--accent);padding:0.2rem 0.5rem;border-radius:999px;font-size:0.75rem;">@item.DESCRIPTION_TYPE_?.TYPE</span></td>
                            <td style="color:var(--muted);font-size:0.875rem;">@(item.PROJECT_?.PROJECT_NAME ?? item.EXPERIENCE_?.INSTITUTE ?? "—")</td>
                            <td>@item.SORT_ORDER</td>
                            <td>
                                <div class="actions">
                                    <a class="action-btn" asp-action="Edit"    asp-route-id="@item.AUTO_ID" title="Edit"><i class="bi bi-pencil"></i></a>
                                    <a class="action-btn" asp-action="Details" asp-route-id="@item.AUTO_ID" title="Details"><i class="bi bi-eye"></i></a>
                                    <a class="action-btn danger" asp-action="Delete" asp-route-id="@item.AUTO_ID" title="Delete"><i class="bi bi-trash"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
        else { <div class="empty-state">No descriptions yet.</div> }
    </div>
</section>
