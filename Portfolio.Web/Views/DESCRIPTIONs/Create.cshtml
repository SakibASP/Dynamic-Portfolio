@model Portfolio.Domain.DESCRIPTION

@{ ViewData["Title"] = "New Description"; }

<section>
    <div class="admin-page narrow">
        <div class="admin-head">
            <div>
                <span class="eyebrow">Admin · Descriptions</span>
                <h2>New description</h2>
            </div>
        </div>

        <form asp-action="Create" class="admin-form">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="field"><label asp-for="DESCRIPTION_TEXT"></label><textarea asp-for="DESCRIPTION_TEXT" rows="4"></textarea><span asp-validation-for="DESCRIPTION_TEXT" class="err"></span></div>
            <div class="field"><label asp-for="TYPE_ID"></label><select asp-for="TYPE_ID" asp-items="ViewBag.TYPE_ID as Microsoft.AspNetCore.Mvc.Rendering.SelectList"><option value="">— select —</option></select><span asp-validation-for="TYPE_ID" class="err"></span></div>
            <div class="field"><label asp-for="PROJECT_ID"></label><select asp-for="PROJECT_ID" asp-items="ViewBag.PROJECT_ID as Microsoft.AspNetCore.Mvc.Rendering.SelectList"><option value="">— select —</option></select><span asp-validation-for="PROJECT_ID" class="err"></span></div>
            <div class="field"><label asp-for="EXPERIENCE_ID"></label><select asp-for="EXPERIENCE_ID" asp-items="ViewBag.EXPERIENCE_ID as Microsoft.AspNetCore.Mvc.Rendering.SelectList"><option value="">— select —</option></select><span asp-validation-for="EXPERIENCE_ID" class="err"></span></div>
            <div class="field"><label asp-for="SORT_ORDER"></label><input asp-for="SORT_ORDER" type="number" /><span asp-validation-for="SORT_ORDER" class="err"></span></div>

            <div class="form-actions">
                <a asp-action="Index" class="btn-ghost">Cancel</a>
                <button type="submit" class="btn-primary-grad"><i class="bi bi-check2"></i> Create</button>
            </div>
        </form>
    </div>
</section>

@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }
