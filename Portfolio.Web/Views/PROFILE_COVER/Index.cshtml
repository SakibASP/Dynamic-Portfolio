@model IEnumerable<Portfolio.Domain.PROFILE_COVER>

@{
    ViewData["Title"] = "Profile Covers";
    var rootpath = (string)ViewBag.rootPath;
}

<section>
    <div class="admin-page">
        <div class="admin-head">
            <div>
                <span class="eyebrow">Admin · Profile Cover</span>
                <h2>All covers</h2>
            </div>
            <a asp-action="Create" class="btn-primary-grad"><i class="bi bi-plus-lg"></i> New cover</a>
        </div>

        @if (Model.Any())
        {
            <div class="admin-table-wrap">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th style="width: 96px;">Image</th>
                            <th>Name</th>
                            <th>Description</th>
                            <th style="width: 160px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @if (item.COVER_IMAGE != null)
                                {
                                    <img class="thumb" src="@Url.Content(item.COVER_IMAGE.Replace(rootpath, ""))" alt="@item.COVER_NAME" />
                                }
                            </td>
                            <td>@item.COVER_NAME</td>
                            <td>@item.COVER_DESC</td>
                            <td>
                                <div class="actions">
                                    <a class="action-btn" asp-action="Edit" asp-route-id="@item.AUTO_ID" title="Edit"><i class="bi bi-pencil"></i></a>
                                    <a class="action-btn" asp-action="Details" asp-route-id="@item.AUTO_ID" title="Details"><i class="bi bi-eye"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state">No covers yet. Create one to get started.</div>
        }
    </div>
</section>
