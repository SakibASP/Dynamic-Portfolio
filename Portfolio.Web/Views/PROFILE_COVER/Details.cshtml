@model Portfolio.Domain.PROFILE_COVER

@{
    ViewData["Title"] = "Cover Details";
    var rootpath = (string)ViewBag.rootPath;
}

<section>
    <div class="admin-page narrow">
        <div class="admin-head">
            <div>
                <span class="eyebrow">Admin · Profile Cover</span>
                <h2>@Model.COVER_NAME</h2>
            </div>
        </div>

        <div class="admin-details">
            <div class="row"><div class="k">Name</div><div class="v">@Model.COVER_NAME</div></div>
            <div class="row"><div class="k">Description</div><div class="v">@Model.COVER_DESC</div></div>
            <div class="row">
                <div class="k">Image</div>
                <div class="v">
                    @if (Model.COVER_IMAGE != null)
                    {
                        <img class="preview" src="@Url.Content(Model.COVER_IMAGE.Replace(rootpath, ""))" alt="@Model.COVER_NAME" />
                    }
                    else { <span style="color: var(--dim);">—</span> }
                </div>
            </div>
        </div>

        <div class="form-actions">
            <a asp-action="Index" class="btn-ghost"><i class="bi bi-arrow-left"></i> Back</a>
            <a asp-action="Edit" asp-route-id="@Model?.AUTO_ID" class="btn-primary-grad"><i class="bi bi-pencil"></i> Edit</a>
        </div>
    </div>
</section>
