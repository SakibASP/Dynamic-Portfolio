@model Portfolio.Domain.PROFILE_COVER

@{
    ViewData["Title"] = "Delete Cover";
}

<section>
    <div class="admin-page narrow">
        <div class="admin-head center">
            <span class="eyebrow">Admin · Profile Cover</span>
            <h2>Delete this cover?</h2>
            <span class="sub">This action cannot be undone.</span>
        </div>

        <div class="admin-details">
            <div class="row"><div class="k">Name</div><div class="v">@Model.COVER_NAME</div></div>
            <div class="row"><div class="k">Description</div><div class="v">@Model.COVER_DESC</div></div>
        </div>

        <form asp-action="Delete" class="form-actions center">
            <input type="hidden" asp-for="AUTO_ID" />
            <a asp-action="Index" class="btn-ghost">Cancel</a>
            <button type="submit" class="btn-danger-solid"><i class="bi bi-trash"></i> Delete</button>
        </form>
    </div>
</section>
