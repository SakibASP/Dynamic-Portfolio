@model Portfolio.Domain.PROFILE_COVER

@{
    ViewData["Title"] = "Edit Cover";
    var rootpath = (string)ViewBag.rootPath;
}

<section>
    <div class="admin-page narrow">
        <div class="admin-head">
            <div>
                <span class="eyebrow">Admin · Profile Cover</span>
                <h2>Edit cover</h2>
            </div>
        </div>

        <form asp-action="Edit" enctype="multipart/form-data" class="admin-form">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="AUTO_ID" />
            <input type="hidden" asp-for="COVER_IMAGE" />

            <div class="field">
                <label asp-for="COVER_NAME"></label>
                <input asp-for="COVER_NAME" />
                <span asp-validation-for="COVER_NAME" class="err"></span>
            </div>
            <div class="field">
                <label asp-for="COVER_DESC"></label>
                <input asp-for="COVER_DESC" />
                <span asp-validation-for="COVER_DESC" class="err"></span>
            </div>

            @if (Model.COVER_IMAGE != null)
            {
                <div class="field">
                    <label>Current image</label>
                    <img class="preview" src="@Url.Content(Model.COVER_IMAGE.Replace(rootpath, ""))" alt="current" />
                </div>
            }

            <div class="field">
                <label asp-for="COVER_IMAGE">Replace image</label>
                <input type="file" id="fileInput" accept="image/*" asp-for="COVER_IMAGE" class="form-control-file" />
                <span asp-validation-for="COVER_IMAGE" class="err"></span>
                <div id="file-preview"></div>
            </div>

            <div class="form-actions">
                <a asp-action="Index" class="btn-ghost">Cancel</a>
                <button type="submit" class="btn-primary-grad"><i class="bi bi-check2"></i> Save</button>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="~/js/file-preview.js"></script>
}
