@model Portfolio.Domain.MY_SKILLS

@{ ViewData["Title"] = "New Skill"; }

<section>
    <div class="admin-page narrow">
        <div class="admin-head">
            <div>
                <span class="eyebrow">Admin · Skills</span>
                <h2>New skill</h2>
            </div>
        </div>

        <form asp-action="Create" class="admin-form">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="field"><label asp-for="SKILL_NAME"></label><input asp-for="SKILL_NAME" /><span asp-validation-for="SKILL_NAME" class="err"></span></div>
            <div class="field"><label asp-for="SKILL_PERCENTAGE"></label><input asp-for="SKILL_PERCENTAGE" type="number" min="0" max="100" /><span asp-validation-for="SKILL_PERCENTAGE" class="err"></span></div>

            <div class="form-actions">
                <a asp-action="Index" class="btn-ghost">Cancel</a>
                <button type="submit" class="btn-primary-grad"><i class="bi bi-check2"></i> Create</button>
            </div>
        </form>
    </div>
</section>

@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }
