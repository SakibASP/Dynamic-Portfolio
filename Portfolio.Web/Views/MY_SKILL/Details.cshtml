@model Portfolio.Domain.MY_SKILLS

@{ ViewData["Title"] = "Skill Details"; }

<section>
    <div class="admin-page narrow">
        <div class="admin-head">
            <div>
                <span class="eyebrow">Admin · Skills</span>
                <h2>@Model.SKILL_NAME</h2>
            </div>
        </div>

        <div class="admin-details">
            <div class="row"><div class="k">Name</div><div class="v">@Model.SKILL_NAME</div></div>
            <div class="row"><div class="k">Percentage</div><div class="v">@Model.SKILL_PERCENTAGE%</div></div>
        </div>

        <div class="form-actions">
            <a asp-action="Index" class="btn-ghost"><i class="bi bi-arrow-left"></i> Back</a>
            <a asp-action="Edit" asp-route-id="@Model?.AUTO_ID" class="btn-primary-grad"><i class="bi bi-pencil"></i> Edit</a>
        </div>
    </div>
</section>
