@model List<Portfolio.Application.DTOs.FileInfoViewModel>
@{ ViewData["Title"] = "Error Logs"; }

<section>
    <div class="admin-page">
        <div class="admin-head">
            <div>
                <span class="eyebrow">Admin · Logs</span>
                <h2 style="color:var(--danger);">Error logs</h2>
            </div>
            <div style="display:flex;gap:0.5rem;">
                <a asp-action="BackupInfoLogs"  class="btn-ghost">Info</a>
                <a asp-action="BackupFatalLogs" class="btn-ghost">Fatal</a>
                <a asp-action="ClearBackupFolder" asp-route-folderName="ErrorLogs" class="btn-ghost" style="color:var(--danger);border-color:rgba(239,68,68,0.3);"><i class="bi bi-trash"></i> Clear</a>
            </div>
        </div>
        @await Html.PartialAsync("_LogTable", Model)
    </div>
</section>
