
@{
    ViewData["Title"] = "CV";
}

<style>
    .cv-container {
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 1.5rem 0;
    }
    .cv-container iframe {
        width: 100%;
        max-width: 1000px;
        height: 80vh;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        background: var(--bg);
    }
</style>

<section>
    <div class="container-fluid py-5">
        <div class="text-center mb-3">
            <a asp-action="DownloadCV" asp-controller="CV" asp-route-filePath="@ViewBag.FilePath" class="btn btn-primary"><i class="bi bi-download"></i> Download</a>
        </div>
        <div class="cv-container">
            <iframe src="@Url.Action("ShowCV", "CV",new{ filePath = @ViewBag.FilePath })"></iframe>
        </div>
    </div>
</section>



