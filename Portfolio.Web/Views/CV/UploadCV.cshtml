@{ ViewData["Title"] = "Upload CV"; }

<section>
    <div class="admin-page narrow">
        <div class="admin-head">
            <div>
                <span class="eyebrow">Admin · CV</span>
                <h2>Upload file</h2>
            </div>
        </div>

        <form id="uploadForm" enctype="multipart/form-data" class="admin-form">
            <div class="field">
                <label>Choose file</label>
                <input type="file" name="file" id="fileInput" />
            </div>
            <div id="file-preview"></div>
            <div id="result" style="margin-top:0.5rem;font-family:var(--font-mono);font-size:0.8125rem;"></div>

            <div class="form-actions">
                <a asp-action="Index" class="btn-ghost">Cancel</a>
                <button type="submit" class="btn-primary-grad"><i class="bi bi-cloud-upload"></i> Upload</button>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <script src="~/js/file-preview.js"></script>
    <script>
        const f = document.getElementById('uploadForm');
        const i = document.getElementById('fileInput');
        const r = document.getElementById('result');
        f.addEventListener('submit', async (e) => {
            e.preventDefault();
            const file = i.files[0];
            if (!file) { r.textContent = 'Please select a file.'; r.style.color = 'var(--danger)'; return; }
            try {
                const fd = new FormData();
                fd.append('file', file);
                const res = await fetch('/upload', { method: 'POST', body: fd });
                if (res.ok) { r.textContent = await res.text(); r.style.color = 'var(--success)'; }
                else { r.textContent = 'Error uploading file.'; r.style.color = 'var(--danger)'; }
            } catch (err) { r.textContent = 'Error: ' + err.message; r.style.color = 'var(--danger)'; }
        });
    </script>
}
