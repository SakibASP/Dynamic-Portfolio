@model Portfolio.Domain.EDUCATION

@{ ViewData["Title"] = "Education Details"; }

<section>
    <div class="admin-page narrow">
        <div class="admin-head">
            <div>
                <span class="eyebrow">Admin · Education</span>
                <h2>@Model.COURSE</h2>
            </div>
        </div>

        <div class="admin-details">
            <div class="row"><div class="k">Course</div><div class="v">@Model.COURSE</div></div>
            <div class="row"><div class="k">Institute</div><div class="v">@Model.INSTITUTE</div></div>
            <div class="row"><div class="k">From</div><div class="v">@Model.FROM_DATE</div></div>
            <div class="row"><div class="k">To</div><div class="v">@Model.TO_DATE</div></div>
            <div class="row"><div class="k">Description</div><div class="v">@Model.DESCRIPTION</div></div>
        </div>

        <div class="form-actions">
            <a asp-action="Index" class="btn-ghost"><i class="bi bi-arrow-left"></i> Back</a>
            <a asp-action="Edit" asp-route-id="@Model?.AUTO_ID" class="btn-primary-grad"><i class="bi bi-pencil"></i> Edit</a>
        </div>
    </div>
</section>
