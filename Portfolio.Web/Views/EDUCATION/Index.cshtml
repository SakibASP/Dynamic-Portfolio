@model IEnumerable<Portfolio.Domain.EDUCATION>

@{ ViewData["Title"] = "Education"; }

<section>
    <div class="admin-page">
        <div class="admin-head">
            <div>
                <span class="eyebrow">Admin · Education</span>
                <h2>All records</h2>
            </div>
            <a asp-action="Create" class="btn-primary-grad"><i class="bi bi-plus-lg"></i> New entry</a>
        </div>

        @if (Model.Any())
        {
            <div class="admin-table-wrap">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>Course</th>
                            <th>Institute</th>
                            <th>From</th>
                            <th>To</th>
                            <th style="width: 160px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.COURSE</td>
                            <td>@item.INSTITUTE</td>
                            <td><span style="font-family: var(--font-mono); font-size: 0.8125rem; color: var(--muted);">@item.FROM_DATE</span></td>
                            <td><span style="font-family: var(--font-mono); font-size: 0.8125rem; color: var(--muted);">@item.TO_DATE</span></td>
                            <td>
                                <div class="actions">
                                    <a class="action-btn" asp-action="Edit"    asp-route-id="@item.AUTO_ID" title="Edit"><i class="bi bi-pencil"></i></a>
                                    <a class="action-btn" asp-action="Details" asp-route-id="@item.AUTO_ID" title="Details"><i class="bi bi-eye"></i></a>
                                    <a class="action-btn danger" asp-action="Delete" asp-route-id="@item.AUTO_ID" title="Delete"><i class="bi bi-trash"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state">No education records yet.</div>
        }
    </div>
</section>
