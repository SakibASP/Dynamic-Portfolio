@model Portfolio.Domain.EDUCATION

@{ ViewData["Title"] = "Edit Education"; }

<section>
    <div class="admin-page narrow">
        <div class="admin-head">
            <div>
                <span class="eyebrow">Admin · Education</span>
                <h2>Edit entry</h2>
            </div>
        </div>

        <form asp-action="Edit" class="admin-form">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="AUTO_ID" />

            <div class="field">
                <label asp-for="COURSE"></label>
                <input asp-for="COURSE" />
                <span asp-validation-for="COURSE" class="err"></span>
            </div>
            <div class="field">
                <label asp-for="INSTITUTE"></label>
                <input asp-for="INSTITUTE" />
                <span asp-validation-for="INSTITUTE" class="err"></span>
            </div>
            <div class="field">
                <label asp-for="FROM_DATE"></label>
                <input asp-for="FROM_DATE" />
                <span asp-validation-for="FROM_DATE" class="err"></span>
            </div>
            <div class="field">
                <label asp-for="TO_DATE"></label>
                <input asp-for="TO_DATE" />
                <span asp-validation-for="TO_DATE" class="err"></span>
            </div>
            <div class="field">
                <label asp-for="DESCRIPTION"></label>
                <textarea asp-for="DESCRIPTION" rows="5"></textarea>
                <span asp-validation-for="DESCRIPTION" class="err"></span>
            </div>

            <div class="form-actions">
                <a asp-action="Index" class="btn-ghost">Cancel</a>
                <button type="submit" class="btn-primary-grad"><i class="bi bi-check2"></i> Save</button>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
