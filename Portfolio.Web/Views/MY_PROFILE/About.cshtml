@using Portfolio.Domain
@addTagHelper*, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "About";
    MY_PROFILE? profile = ViewData["PROFILES"] as MY_PROFILE;
    List<MY_SKILLS>? skills = ViewData["SKILLS"] as List<MY_SKILLS>;
    var rootpath = (string)ViewBag.rootPath;
}

<!-- SVG defs for skill ring gradient — reused by every ring -->
<svg width="0" height="0" style="position:absolute">
    <defs>
        <linearGradient id="ringGrad" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#8b5cf6" />
            <stop offset="100%" stop-color="#06b6d4" />
        </linearGradient>
    </defs>
</svg>

<main id="main">
    @if (profile != null)
    {
        <section id="about" class="about">
            <div class="container" data-aos="fade-up">
                <div class="section-title">
                    <h2>About</h2>
                    <p>@profile.DES_1</p>
                </div>

                <div class="row g-4 align-items-start">
                    @if (profile.PROFILE_IMAGE != null)
                    {
                        <div class="col-lg-4" data-aos="zoom-in" data-aos-delay="100">
                            <img class="img-fluid about-photo" src="@Url.Content(profile.PROFILE_IMAGE.Replace(rootpath, ""))" alt="@profile.MY_NAME" />
                        </div>
                    }
                    <div class="col-lg-8 content" data-aos="fade-up" data-aos-delay="200">
                        <h3 id="changing-heading">@profile.DESIGNATION</h3>
                        <p class="fst-italic">@profile.DES_2</p>
                        <div class="row">
                            <div class="col-lg-6">
                                <ul>
                                    @if (profile.DATE_OF_BIRTH.HasValue)
                                    {
                                        <li><strong>Birth Date:</strong>&nbsp;<span id="DateOfBirth">@profile.DATE_OF_BIRTH.Value.ToShortDateString()</span></li>
                                    }
                                    <li><strong>Website:</strong>&nbsp;@profile.MY_WEBSITE</li>
                                    <li><strong>Phone:</strong>&nbsp;@profile.PHONE</li>
                                    <li><strong>City:</strong>&nbsp;@profile.CURRENT_CITY</li>
                                </ul>
                            </div>
                            <div class="col-lg-6">
                                <ul>
                                    <li><strong>Age:</strong>&nbsp;<span id="Age"></span></li>
                                    <li><strong>Degree:</strong>&nbsp;@profile.DEGREE</li>
                                    <li><strong>Email:</strong>&nbsp;@profile.EMAIL</li>
                                    <li><strong>Home Town:</strong>&nbsp;@profile.HOMETOWN</li>
                                </ul>
                            </div>
                        </div>
                        <p>@profile.DES_3</p>
                    </div>
                </div>
            </div>
        </section>
    }
    else
    {
        <section><div class="container"><p>No profile found.</p></div></section>
    }

    @if (skills != null && skills.Any())
    {
        <section id="skills" class="skills">
            <div class="container" data-aos="fade-up">
                <div class="section-title">
                    <h2>Skills</h2>
                    <p>What I bring to the keyboard every day</p>
                </div>

                <div class="skills-grid">
                    @foreach (var (item, idx) in skills.Select((s, i) => (s, i)))
                    {
                        var pct = item.SKILL_PERCENTAGE ?? 0;
                        var circumference = 2 * Math.PI * 52;
                        var offset = circumference * (1 - pct / 100.0);
                        <div class="skill-ring" data-aos="zoom-in" data-aos-delay="@(idx * 60)">
                            <svg viewBox="0 0 120 120">
                                <circle class="track" cx="60" cy="60" r="52" fill="none" stroke-width="8" />
                                <circle class="bar" cx="60" cy="60" r="52" fill="none" stroke-width="8"
                                        stroke-dasharray="@circumference.ToString("0.00")"
                                        stroke-dashoffset="@offset.ToString("0.00")" />
                                <text class="pct" x="60" y="66" text-anchor="middle">@pct%</text>
                            </svg>
                            <div class="name">@item.SKILL_NAME</div>
                        </div>
                    }
                </div>
            </div>
        </section>
    }
</main>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        var el = document.getElementById("DateOfBirth");
        if (!el) return;
        var birthDate = new Date(el.textContent);
        var today = new Date();
        var age = today.getFullYear() - birthDate.getFullYear();
        var m = today.getMonth() - birthDate.getMonth();
        if (m < 0 || (m === 0 && today.getDate() < birthDate.getDate())) age--;
        document.getElementById("Age").textContent = age;
    });
</script>
