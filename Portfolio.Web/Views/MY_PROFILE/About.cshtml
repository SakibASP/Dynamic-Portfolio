@using Portfolio.Domain
@addTagHelper*, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "About";
    MY_PROFILE? profile = ViewData["PROFILES"] as MY_PROFILE;
    List<MY_SKILLS>? skills = ViewData["SKILLS"] as List<MY_SKILLS>;
    var rootpath = (string)ViewBag.rootPath;
}

<main id="main">
    @if (profile != null)
    {
        <section id="about" class="about">
            <div class="container">
                <div class="section-title">
                    <span class="eyebrow">About me</span>
                    <h2>@profile.DESIGNATION</h2>
                    @if (!string.IsNullOrWhiteSpace(profile.DES_1)) { <p>@profile.DES_1</p> }
                </div>

                <div class="row g-4 align-items-start">
                    @if (profile.PROFILE_IMAGE != null)
                    {
                        <div class="col-lg-4" data-aos="fade-up">
                            <img class="about-photo" src="@Url.Content(profile.PROFILE_IMAGE.Replace(rootpath, ""))" alt="@profile.MY_NAME" />
                        </div>
                    }
                    <div class="col-lg-8 content" data-aos="fade-up" data-aos-delay="100">
                        @if (!string.IsNullOrWhiteSpace(profile.DES_2))
                        {
                            <p class="fst-italic">@profile.DES_2</p>
                        }

                        <ul>
                            @if (profile.DATE_OF_BIRTH.HasValue)
                            {
                                <li><strong>Born</strong><span id="DateOfBirth">@profile.DATE_OF_BIRTH.Value.ToShortDateString()</span></li>
                            }
                            <li><strong>Age</strong><span id="Age"></span></li>
                            <li><strong>Degree</strong><span>@profile.DEGREE</span></li>
                            <li><strong>Email</strong><span>@profile.EMAIL</span></li>
                            <li><strong>Phone</strong><span>@profile.PHONE</span></li>
                            <li><strong>City</strong><span>@profile.CURRENT_CITY</span></li>
                            <li><strong>Hometown</strong><span>@profile.HOMETOWN</span></li>
                            <li><strong>Website</strong><span>@profile.MY_WEBSITE</span></li>
                        </ul>

                        @if (!string.IsNullOrWhiteSpace(profile.DES_3))
                        {
                            <p>@profile.DES_3</p>
                        }
                    </div>
                </div>
            </div>
        </section>
    }

    @if (skills != null && skills.Any())
    {
        <section id="skills" class="skills">
            <div class="container">
                <div class="section-title">
                    <span class="eyebrow">Toolkit</span>
                    <h2>Skills</h2>
                    <p>What I reach for day-to-day.</p>
                </div>

                <div class="skills-list">
                    @foreach (var item in skills)
                    {
                        var pct = item.SKILL_PERCENTAGE ?? 0;
                        <div class="skill-row" data-aos="fade-up">
                            <div class="skill-head">
                                <span class="skill-name">@item.SKILL_NAME</span>
                                <span class="skill-val">@pct%</span>
                            </div>
                            <div class="track">
                                <div class="fill" style="width:@pct%;"></div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </section>
    }
</main>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        var el = document.getElementById("DateOfBirth");
        if (!el) return;
        var b = new Date(el.textContent);
        var t = new Date();
        var a = t.getFullYear() - b.getFullYear();
        var m = t.getMonth() - b.getMonth();
        if (m < 0 || (m === 0 && t.getDate() < b.getDate())) a--;
        document.getElementById("Age").textContent = a;
    });
</script>
