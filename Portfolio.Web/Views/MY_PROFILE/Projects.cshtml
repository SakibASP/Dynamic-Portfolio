@using Portfolio.Domain
@addTagHelper*, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "Projects";
    MY_PROFILE? profile = ViewData["PROFILES"] as MY_PROFILE;
    List<PROJECTS>? projects = ViewData["PROJECTS"] as List<PROJECTS>;
}

<main id="main">
    <section>
        <div class="container" data-aos="fade-up">
            <div class="section-title">
                <h2 id="changing-heading">Projects</h2>
                @if (profile != null) { <p>@profile.DES_1</p> }
            </div>

            @if (projects != null && projects.Any())
            {
                <div class="project-grid">
                    @foreach (var (item, idx) in projects.Select((p, i) => (p, i)))
                    {
                        <article class="project-card js-tilt" data-aos="fade-up" data-aos-delay="@(idx * 80)">
                            <div class="thumb">
                                @if (item.LOGO != null && item.LOGO.Length > 0)
                                {
                                    <img src="data:image/*;base64,@System.Convert.ToBase64String(item.LOGO)" alt="@item.PROJECT_NAME" />
                                }
                            </div>
                            <div class="body">
                                <h3 class="name" title="@item.PROJECT_NAME">@item.PROJECT_NAME</h3>
                                <a class="view-btn" asp-action="Details" asp-controller="PROJECTS" asp-route-id="@item.AUTO_ID">
                                    View details <i class="bi bi-arrow-right"></i>
                                </a>
                            </div>
                        </article>
                    }
                </div>
            }
            else
            {
                <p>No works to display yet.</p>
            }
        </div>
    </section>
</main>

@section Scripts {
    <script>
        /* Lightweight 3D tilt on hover — no library */
        document.querySelectorAll(".js-tilt").forEach(card => {
            const MAX = 8;
            card.addEventListener("mousemove", e => {
                const r = card.getBoundingClientRect();
                const x = (e.clientX - r.left) / r.width  - 0.5;
                const y = (e.clientY - r.top)  / r.height - 0.5;
                card.style.transform = `perspective(900px) rotateY(${x * MAX}deg) rotateX(${-y * MAX}deg) translateY(-4px)`;
            });
            card.addEventListener("mouseleave", () => { card.style.transform = ""; });
        });
    </script>
}
