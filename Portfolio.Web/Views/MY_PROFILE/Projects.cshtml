@using Portfolio.Domain
@addTagHelper*, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "Projects";
    MY_PROFILE? profile = ViewData["PROFILES"] as MY_PROFILE;
    List<PROJECTS>? projects = ViewData["PROJECTS"] as List<PROJECTS>;
}

<main id="main">
    <section>
        <div class="container">
            <div class="section-title">
                <span class="eyebrow">Selected work</span>
                <h2>Projects</h2>
                @if (profile != null && !string.IsNullOrWhiteSpace(profile.DES_1)) { <p>@profile.DES_1</p> }
            </div>

            @if (projects != null && projects.Any())
            {
                <div class="project-grid">
                    @foreach (var (item, idx) in projects.Select((p, i) => (p, i)))
                    {
                        <article class="project-card" data-aos="fade-up" data-aos-delay="@(idx * 60)">
                            <div class="thumb">
                                @if (item.LOGO != null && item.LOGO.Length > 0)
                                {
                                    <img src="data:image/*;base64,@System.Convert.ToBase64String(item.LOGO)" alt="@item.PROJECT_NAME" />
                                }
                            </div>
                            <div class="body">
                                <span class="idx">No. @((idx + 1).ToString("00"))</span>
                                <h3 class="name" title="@item.PROJECT_NAME">@item.PROJECT_NAME</h3>
                                <a class="view" asp-action="Details" asp-controller="PROJECTS" asp-route-id="@item.AUTO_ID">
                                    Case study <i class="bi bi-arrow-right"></i>
                                </a>
                            </div>
                        </article>
                    }
                </div>
            }
            else
            {
                <p>No projects to show yet.</p>
            }
        </div>
    </section>
</main>
