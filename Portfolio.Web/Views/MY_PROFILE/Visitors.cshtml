@using X.PagedList
@using X.PagedList.Mvc.Core
@model IPagedList<Portfolio.Application.DTOs.VisitorsViewModel>

@{
    ViewData["Title"] = "Visitors";
    var IsAuthenticated = (bool)ViewBag.IsAuthenticated;
}

<link href="~/css/pagedlist.css" rel="stylesheet" />

<style>
    .visitors-wrap { max-width: 960px; margin: 0 auto; padding: 2rem 1rem; }

    .visitors-head { text-align: center; margin-bottom: 2rem; }
    .visitors-head .count {
        font-size: clamp(2rem, 4vw, 2.75rem);
        font-weight: 600;
        color: var(--text);
        letter-spacing: -0.02em;
        margin: 0;
    }
    .visitors-head .count span { color: var(--accent); }
    .visitors-head .sub {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--dim);
        margin-top: 0.25rem;
    }

    .filter-panel {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 1rem 1.25rem;
        margin-bottom: 1.5rem;
    }

    .filter-toggle {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        background: transparent;
        border: 1px solid var(--border-hi);
        color: var(--text);
        border-radius: var(--radius-sm);
        padding: 0.375rem 0.75rem;
        font-size: 0.8125rem;
        font-family: var(--font-mono);
        cursor: pointer;
        transition: background 0.15s var(--ease);
    }
    .filter-toggle:hover { background: var(--surface-hi); }

    .filter-form { margin-top: 1rem; }
    .filter-form label {
        display: block;
        font-family: var(--font-mono);
        font-size: 0.6875rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--dim);
        margin-bottom: 0.375rem;
    }

    .btn-filter-submit {
        width: 100%;
        background: var(--accent);
        color: var(--accent-ink);
        border: 1px solid var(--accent);
        border-radius: var(--radius-sm);
        padding: 0.55rem 1rem;
        font-weight: 600;
        font-size: 0.8125rem;
        cursor: pointer;
        transition: background 0.15s var(--ease);
    }
    .btn-filter-submit:hover { background: var(--accent-hi); color: var(--accent-ink); }

    .visitor-list { display: grid; gap: 0.625rem; }

    .visitor-card {
        position: relative;
        background: var(--surface);
        border: 1px solid var(--border);
        border-left: 3px solid var(--border);
        border-radius: var(--radius);
        padding: 1rem 1.25rem;
        transition: border-color 0.15s var(--ease), background 0.15s var(--ease);
        animation: vFadeUp 0.35s var(--ease) both;
    }
    .visitor-card:hover {
        border-color: var(--border-hi);
        border-left-color: var(--accent);
        background: var(--surface-hi);
    }

    .visitor-card .top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.5rem;
        flex-wrap: wrap;
        margin-bottom: 0.75rem;
    }

    .visitor-card .loc { display: flex; align-items: center; gap: 0.625rem; min-width: 0; }
    .visitor-card .country {
        display: inline-flex;
        align-items: center;
        padding: 0.25rem 0.625rem;
        background: rgba(190, 242, 100, 0.08);
        border: 1px solid rgba(190, 242, 100, 0.25);
        color: var(--accent);
        font-size: 0.75rem;
        font-weight: 600;
        border-radius: 999px;
        letter-spacing: 0.02em;
    }
    .visitor-card .city { color: var(--text); font-size: 0.9375rem; font-weight: 500; }

    .visitor-card .time {
        font-family: var(--font-mono);
        color: var(--dim);
        font-size: 0.75rem;
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
    }

    .visitor-card .chips { display: flex; flex-wrap: wrap; gap: 0.375rem 0.5rem; align-items: center; }

    .visitor-card .chip {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        background: var(--bg-elev);
        color: var(--muted);
        border: 1px solid var(--border);
        padding: 0.25rem 0.625rem;
        border-radius: var(--radius-sm);
        font-family: var(--font-mono);
        font-size: 0.75rem;
    }
    .visitor-card .chip.ip { color: var(--accent); border-color: rgba(190, 242, 100, 0.2); background: rgba(190, 242, 100, 0.05); }
    .visitor-card .chip i { opacity: 0.75; }

    .visitor-card .go {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        background: transparent;
        color: var(--text);
        border: 1px solid var(--border-hi);
        padding: 0.3rem 0.65rem;
        border-radius: var(--radius-sm);
        font-family: var(--font-mono);
        font-size: 0.75rem;
        text-decoration: none;
        transition: background 0.15s var(--ease), color 0.15s var(--ease), border-color 0.15s var(--ease);
    }
    .visitor-card .go:hover { background: var(--accent); color: var(--accent-ink); border-color: var(--accent); }

    .pagination-wrap {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 1rem;
        margin-top: 2rem;
        flex-wrap: wrap;
    }
    .pagination-wrap .page-info {
        font-family: var(--font-mono);
        color: var(--dim);
        font-size: 0.75rem;
    }

    @@keyframes vFadeUp {
        from { opacity: 0; transform: translateY(6px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    .visitor-card:nth-child(1)  { animation-delay: 0.02s; }
    .visitor-card:nth-child(2)  { animation-delay: 0.05s; }
    .visitor-card:nth-child(3)  { animation-delay: 0.08s; }
    .visitor-card:nth-child(4)  { animation-delay: 0.11s; }
    .visitor-card:nth-child(5)  { animation-delay: 0.14s; }
    .visitor-card:nth-child(6)  { animation-delay: 0.17s; }
    .visitor-card:nth-child(7)  { animation-delay: 0.20s; }
    .visitor-card:nth-child(8)  { animation-delay: 0.23s; }
    .visitor-card:nth-child(9)  { animation-delay: 0.26s; }
    .visitor-card:nth-child(10) { animation-delay: 0.29s; }
</style>

<section>
    <div class="visitors-wrap">
        <div class="visitors-head">
            <h1 class="count"><span>@ViewBag.TotalRecords</span> Visitors</h1>
            <div class="sub">explored this portfolio</div>
        </div>

        <div class="filter-panel">
            <button type="button" id="filterToggleButton" class="filter-toggle">
                <i id="filterToggleIcon" class="bi bi-funnel"></i> Filter
            </button>
            <div id="filterFormContainer">
                <form asp-action="Visitors" class="filter-form">
                    <div class="row g-3 align-items-end">
                        <div class="col-sm-6 col-md-3">
                            <label for="startDate">From</label>
                            <input class="form-control" id="startDate" name="startDate" type="date" value="@ViewBag.StartDate" />
                        </div>
                        <div class="col-sm-6 col-md-3">
                            <label for="endDate">To</label>
                            <input class="form-control" id="endDate" name="endDate" type="date" value="@ViewBag.EndDate" />
                        </div>
                        <div class="col-sm-8 col-md-4">
                            <label for="searchString">Search</label>
                            <input class="form-control" id="searchString" name="searchString" type="text" value="@ViewBag.SearchString" placeholder="Country, city, device…" />
                        </div>
                        <div class="col-sm-4 col-md-2">
                            <button type="submit" class="btn-filter-submit">View</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <div class="visitor-list">
            @foreach (var item in Model)
            {
                <div class="visitor-card">
                    <div class="top">
                        <div class="loc">
                            @if (!string.IsNullOrEmpty(item.Country)) { <span class="country">@item.Country</span> }
                            @if (!string.IsNullOrEmpty(item.City))    { <span class="city">@item.City</span> }
                        </div>
                        <span class="time"><i class="bi bi-clock"></i> @item.VisitTime.ToString("dd MMM yyyy, hh:mm tt")</span>
                    </div>
                    <div class="chips">
                        @if (!string.IsNullOrEmpty(item.OperatingSystem)) { <span class="chip"><i class="bi bi-laptop"></i> @item.OperatingSystem</span> }
                        @if (!string.IsNullOrEmpty(item.Browser))         { <span class="chip"><i class="bi bi-globe2"></i> @item.Browser</span> }
                        @if (!string.IsNullOrEmpty(item.DeviceBrand))     { <span class="chip"><i class="bi bi-phone"></i> @item.DeviceBrand</span> }
                        @if (IsAuthenticated && !string.IsNullOrEmpty(item.IPAddress)) { <span class="chip ip"><i class="bi bi-shield-lock"></i> @item.IPAddress</span> }
                        @if (!string.IsNullOrEmpty(item.Latitude) && !string.IsNullOrEmpty(item.Longitude))
                        {
                            <a href="https://www.google.com/maps?q=@item.Latitude,@item.Longitude" target="_blank" class="go">
                                <i class="bi bi-geo-alt-fill"></i> Map
                            </a>
                        }
                    </div>
                </div>
            }
        </div>

        <div class="pagination-wrap">
            <span class="page-info">Page @(Model.PageCount < Model.PageNumber ? 0 : Model.PageNumber) of @Model.PageCount</span>
            @Html.PagedListPager(Model, page => Url.Action("Visitors", new { page, searchString = ViewBag.SearchString, startDate = ViewBag.StartDate, endDate = ViewBag.EndDate }))
        </div>
    </div>
</section>
