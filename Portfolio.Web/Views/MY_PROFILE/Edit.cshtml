@model Portfolio.Domain.MY_PROFILE

@{
    ViewData["Title"] = "Edit Profile";
    var rootpath = (string)ViewBag.rootPath;
}

<section>
    <div class="admin-page narrow">
        <div class="admin-head">
            <div>
                <span class="eyebrow">Admin · Profile</span>
                <h2>Edit profile</h2>
            </div>
        </div>

        <form asp-action="Edit" enctype="multipart/form-data" class="admin-form">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="AUTO_ID" />
            <input type="hidden" asp-for="PROFILE_IMAGE" />

            <div class="field"><label asp-for="MY_NAME"></label><input asp-for="MY_NAME" /><span asp-validation-for="MY_NAME" class="err"></span></div>
            <div class="field"><label asp-for="DESIGNATION"></label><input asp-for="DESIGNATION" /><span asp-validation-for="DESIGNATION" class="err"></span></div>
            <div class="field"><label asp-for="DATE_OF_BIRTH"></label><input asp-for="DATE_OF_BIRTH" type="date" /><span asp-validation-for="DATE_OF_BIRTH" class="err"></span></div>
            <div class="field"><label asp-for="MY_WEBSITE"></label><input asp-for="MY_WEBSITE" /><span asp-validation-for="MY_WEBSITE" class="err"></span></div>
            <div class="field"><label asp-for="DEGREE"></label><input asp-for="DEGREE" /><span asp-validation-for="DEGREE" class="err"></span></div>
            <div class="field"><label asp-for="PHONE"></label><input asp-for="PHONE" /><span asp-validation-for="PHONE" class="err"></span></div>
            <div class="field"><label asp-for="EMAIL"></label><input asp-for="EMAIL" type="email" /><span asp-validation-for="EMAIL" class="err"></span></div>
            <div class="field"><label asp-for="CURRENT_CITY"></label><input asp-for="CURRENT_CITY" /><span asp-validation-for="CURRENT_CITY" class="err"></span></div>
            <div class="field"><label asp-for="HOMETOWN"></label><input asp-for="HOMETOWN" /><span asp-validation-for="HOMETOWN" class="err"></span></div>
            <div class="field"><label asp-for="STATUS">Status (hero chip)</label><input asp-for="STATUS" placeholder="e.g. Open to work" /></div>
            <div class="field"><label asp-for="TECH_STACK">Tech stack (hero chip)</label><input asp-for="TECH_STACK" placeholder=".NET · SQL · Clean Arch" /></div>
            <div class="field"><label asp-for="DES_1"></label><textarea asp-for="DES_1" rows="4"></textarea><span asp-validation-for="DES_1" class="err"></span></div>
            <div class="field"><label asp-for="DES_2"></label><textarea asp-for="DES_2" rows="4"></textarea><span asp-validation-for="DES_2" class="err"></span></div>
            <div class="field"><label asp-for="DES_3"></label><textarea asp-for="DES_3" rows="4"></textarea><span asp-validation-for="DES_3" class="err"></span></div>

            @if (Model.PROFILE_IMAGE != null)
            {
                <div class="field">
                    <label>Current image</label>
                    <img class="preview" src="@Url.Content(Model.PROFILE_IMAGE.Replace(rootpath, ""))" alt="current" />
                </div>
            }

            <div class="field">
                <label asp-for="PROFILE_IMAGE">Replace image</label>
                <input type="file" id="fileInput" accept="image/*" asp-for="PROFILE_IMAGE" class="form-control-file" />
                <span asp-validation-for="PROFILE_IMAGE" class="err"></span>
                <div id="file-preview"></div>
            </div>

            <div class="form-actions">
                <a asp-action="Index" class="btn-ghost">Cancel</a>
                <button type="submit" class="btn-primary-grad"><i class="bi bi-check2"></i> Save</button>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="~/js/file-preview.js"></script>
}
