@model IEnumerable<Portfolio.Domain.MY_PROFILE>

@{
    ViewData["Title"] = "Profiles";
    var rootpath = (string)ViewBag.rootPath;
}

<section>
    <div class="admin-page">
        <div class="admin-head">
            <div>
                <span class="eyebrow">Admin · Profile</span>
                <h2>All profiles</h2>
            </div>
            <a asp-action="Create" class="btn-primary-grad"><i class="bi bi-plus-lg"></i> New profile</a>
        </div>

        @if (Model.Any())
        {
            <div class="admin-table-wrap">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th style="width:80px;">Photo</th>
                            <th>Name</th>
                            <th>Designation</th>
                            <th>Email</th>
                            <th style="width:120px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @if (item.PROFILE_IMAGE != null)
                                {
                                    <img class="thumb" src="@Url.Content(item.PROFILE_IMAGE.Replace(rootpath,""))" alt="@item.MY_NAME" />
                                }
                            </td>
                            <td>@item.MY_NAME</td>
                            <td>@item.DESIGNATION</td>
                            <td>@item.EMAIL</td>
                            <td>
                                <div class="actions">
                                    <a class="action-btn" asp-action="Edit"    asp-route-id="@item.AUTO_ID" title="Edit"><i class="bi bi-pencil"></i></a>
                                    <a class="action-btn" asp-action="Details" asp-route-id="@item.AUTO_ID" title="Details"><i class="bi bi-eye"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
        else { <div class="empty-state">No profiles yet.</div> }
    </div>
</section>
