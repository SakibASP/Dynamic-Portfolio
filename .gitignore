################################################################################
# Dynamic-Portfolio .gitignore
################################################################################

# Visual Studio
/.vs
*.csproj.user
*.user
*.suo

# Build artifacts — applies to every project, every TFM
**/bin/
**/obj/

# Logs (keep folder structure untracked)
/Portfolio.Web/Logs/

# Secrets / local files — never commit
/Portfolio.Application/Common/EmailSettings.cs
/Portfolio.Application/Common/EncryptionHelper.cs

# OS / editor junk
.DS_Store
Thumbs.db
